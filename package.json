{
  "name": "onbuy-repricer-backend",
  "version": "1.0.0",
  "description": "OnBuy Re-Pricer — Amazon scraper + background job + API",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "job": "node repricerJob.js",
    "dev:job": "node --watch repricerJob.js",
    "db:setup": "psql $DATABASE_URL -f database/schema.sql"
  },
  "overrides": {
    "undici": "5"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.76.10",
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "https-proxy-agent": "^7.0.6",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "node-fetch": "^3.3.2",
    "pg": "^8.12.0",
    "puppeteer": "^22.12.1",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "user-agents": "^1.1.305",
    "xlsx": "^0.18.5"
  }
}
